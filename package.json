{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @workspace/f2-finheal dev",
    "build": "pnpm run typecheck && pnpm --filter @workspace/f2-finheal run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter @workspace/f2-finheal --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "react-markdown": "^8.0.7",
    "remark-gfm": "^3.0.1"
  },
  "devDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.60.4",
    "@tailwindcss/oxide": "4.3.0",
    "@tailwindcss/oxide-darwin-arm64": "4.3.0",
    "@types/node": "catalog:",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}