# =============================================================================
# Frontend Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values for your environment
#
# VITE_API_BASE_URL: The backend API address
#   Development (local codespace): http://localhost:8000/api/v1
#   Development (other machine):   http://127.0.0.1:8000/api/v1 or your-backend-url
#   Production:                     https://your-domain.com/api/v1
#
# Important: Vite automatically prefixes env vars with VITE_
# So VITE_API_BASE_URL is the correct name (not API_BASE_URL)
# =============================================================================

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_KEY=
VITE_USER_ID=
